# 七、构建未来 Hazard

def build_future_hazard(cfg: ScenarioConfig):
    """
    基于 CMIP6 情景配置构建未来台风危险性 Hazard。

    流程：
      1. load_cmip6_data()              → 读取 CMIP6 气候要素
      2. generate_future_tc_tracks()    → 生成未来台风轨迹集合
      3. Centroids.from_pnt_bounds()    → 建立研究区 centroid 网格
      4. TropCyclone.from_tracks()      → 计算风场、生成 Hazard

    Parameters
    ----------
    cfg : ScenarioConfig

    Returns
    -------
    haz    : climada.hazard.TropCyclone
    tracks : climada.hazard.TCTracks
    """
    from climada.hazard import TropCyclone, Centroids

    print(f" 构建未来 Hazard：{cfg.name} / {cfg.gcm} / {cfg.ensemble}")
    print(f" 未来气候期：{cfg.future_period[0]}–{cfg.future_period[1]}")

    print("\n[Step 1] 加载 CMIP6 气候要素…")
    climate_data = load_cmip6_data(cfg)

    print("\n[Step 2] 生成未来台风轨迹…")
    tracks = generate_future_tc_tracks(cfg, climate_data)
    print(f"  轨迹总数: {tracks.size}")

    print("\n[Step 3] 构建研究区 Centroid 网格…")
    cent = Centroids.from_pnt_bounds(
        points_bounds=cfg.region_bounds,
        res=0.02,
    )
    print(f"  Centroid 数: {cent.size}")

    print("\n[Step 4] 计算台风风场（TropCyclone.from_tracks）…")
    haz = TropCyclone.from_tracks(
        tracks,
        centroids=cent,
        store_windfields=False,
    )
    print(f"  Hazard 事件数: {haz.size}  Centroid 数: {haz.centroids.size}")

    return haz, tracks



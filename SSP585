# 五、CMIP6 数据读取

def load_cmip6_data(cfg: ScenarioConfig) -> dict:
    """
    读取 CMIP6 气候要素（SST / 风切变 / SLP）。

    实际生产中应从 NetCDF 文件读取，路径示例：
        /data/cmip6/{cfg.gcm}/{cfg.ensemble}/sst_ssp585_*.nc

    当前实现使用随机数替代，但数据结构与真实场景完全一致：
      - sst       : 海面温度（℃ 异常），shape (lat, lon)
      - wind_shear: 200–850 hPa 垂直风切变（m/s），shape (lat, lon)
      - slp       : 海平面气压（hPa 异常），shape (lat, lon)

    Parameters
    ----------
    cfg : ScenarioConfig

    Returns
    -------
    dict with keys: "sst", "wind_shear", "slp"
      每个值均为 numpy.ndarray，shape (100, 100)
    """
    lon_min, lat_min, lon_max, lat_max = cfg.region_bounds

    # ── 构建空间网格（与真实 CMIP6 格点结构一致） ────────────────────────────
    n_lat, n_lon = 100, 100
    lons = np.linspace(lon_min - 5, lon_max + 5, n_lon)   # 扩展研究区外围
    lats = np.linspace(lat_min - 5, lat_max + 5, n_lat)

    rng = np.random.default_rng(seed=2085)   # 固定种子保证可复现

    # ── SST：未来升温背景 + 空间变率（单位：℃ 相对基准期） ──────────────────
    # SSP585 情景下 2031–2060 年 WNP 平均 SST 升温约 +0.8–1.5 ℃
    future_warming = 1.1   # ℃
    sst_anomaly = (
        rng.normal(loc=future_warming, scale=0.4, size=(n_lat, n_lon))
        + 0.3 * np.sin(np.linspace(0, np.pi, n_lon))    # 纬向变率
    )

    # ── 风切变：SSP585 下热带气旋活跃区风切变轻微增强（m/s） ─────────────────
    wind_shear = rng.normal(loc=8.5, scale=2.0, size=(n_lat, n_lon))
    wind_shear = np.clip(wind_shear, 0, 25)

    # ── SLP：低值系统频率（hPa 负异常代表深对流活跃） ────────────────────────
    slp_anomaly = rng.normal(loc=-0.5, scale=1.2, size=(n_lat, n_lon))

    print(f"  [CMIP6] 模式: {cfg.gcm} / {cfg.ensemble} / {cfg.name}")
    print(f"  [CMIP6] 未来期: {cfg.future_period[0]}–{cfg.future_period[1]}")
    print(f"  [CMIP6] SST 升温均值: {sst_anomaly.mean():.2f} ℃  "
          f"风切变均值: {wind_shear.mean():.2f} m/s")

    return {
        "sst":        sst_anomaly,
        "wind_shear": wind_shear,
        "slp":        slp_anomaly,
        "lons":       lons,
        "lats":       lats,
    }



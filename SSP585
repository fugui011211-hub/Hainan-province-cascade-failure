# 十一、绘图函数（保持不变）

def _plot_impact(
    gdf_hospital, gdf_school, gdf_power, gdf_road,
    hospital_impact, school_impact, power_impact, road_impact,
    affected_gdf_buf, event_idx,
    track_lon, track_lat,
    strong_events
):
    fig, ax = plt.subplots(figsize=(14, 11))
    plt.subplots_adjust(right=0.78, top=0.92)

    gdf_road.plot(ax=ax, color=TYPE_COLOR["road"], linewidth=0.4, zorder=1, label="_nolegend_")
    gdf_power.plot(ax=ax, color=TYPE_COLOR["power"], linewidth=0.6, zorder=2, label="_nolegend_")
    gdf_hospital.plot(ax=ax, color=TYPE_COLOR["hospital"], markersize=2, zorder=5, label="_nolegend_")
    gdf_school.plot(ax=ax, color=TYPE_COLOR["school"], markersize=2, zorder=4, label="_nolegend_")

    # 台风路径（仅显示窗口范围内的部分）
    mask = (
        (track_lon >= 108) & (track_lon <= 112) &
        (track_lat >= 17)  & (track_lat <= 21)
    )
    ax.plot(track_lon[mask], track_lat[mask],
            color="blue", linewidth=2, linestyle="--", zorder=6)
    if mask.sum() >= 2:
        x_end = track_lon[mask][-1]
        y_end = track_lat[mask][-1]
        x_prev = track_lon[mask][-2]
        y_prev = track_lat[mask][-2]

        ax.annotate(
            '',
            xy=(x_end, y_end),  # 箭头终点（台风最后位置）
            xytext=(x_prev, y_prev),  # 箭头起点（倒数第二个点）
            arrowprops=dict(
                arrowstyle='->',
                color='blue',
                lw=2
            ),
            zorder=7
        )

    def _plot_colored_lines(gdf_imp, zorder, linewidth=0.6):
        if len(gdf_imp) == 0:
            return
        for color, group in gdf_imp.groupby("color_hex"):
            gpd.GeoDataFrame(group, geometry=group.geometry, crs=gdf_imp.crs).plot(
                ax=ax, color=str(color), linewidth=linewidth, zorder=zorder
            )

    def _plot_colored_points(gdf_imp, zorder, markersize=3, marker="o"):
        if len(gdf_imp) == 0:
            return
        for color, group in gdf_imp.groupby("color_hex"):
            gpd.GeoDataFrame(group, geometry=group.geometry, crs=gdf_imp.crs).plot(
                ax=ax, color=str(color), markersize=markersize,
                marker=marker, zorder=zorder
            )

    _plot_colored_lines(road_impact,      zorder=2, linewidth=0.4)
    _plot_colored_lines(power_impact,     zorder=3, linewidth=0.7)
    _plot_colored_points(hospital_impact, zorder=5, markersize=1, marker="^")
    _plot_colored_points(school_impact,   zorder=4, markersize=1, marker="o")

    type_handles = [
        mlines.Line2D([], [], color="blue", linestyle="--", linewidth=2,
                      label="台风路径"),
        mlines.Line2D([], [], color=TYPE_COLOR["road"],
                      linewidth=1.5, label=f"道路（共{len(road_impact)}）"),
        mlines.Line2D([], [], color=TYPE_COLOR["power"],
                      linewidth=1.5, label=f"电力（共{len(power_impact)}）"),
        mlines.Line2D([], [], color=TYPE_COLOR["hospital"],
                      marker="^", linestyle="None", markersize=6,
                      label=f"医院（共{len(hospital_impact)}）"),
        mlines.Line2D([], [], color=TYPE_COLOR["school"],
                      marker="o", linestyle="None", markersize=6,
                      label=f"学校（共{len(school_impact)}）"),
    ]
    risk_labels = [
        "风险1 (0–0.2)", "风险2 (0.2–0.4)", "风险3 (0.4–0.6)",
        "风险4 (0.6–0.8)", "风险5 (0.8–1.0)"
    ]
    risk_handles = [
        mpatches.Patch(color=RED_LEVELS[i], label=risk_labels[i])
        for i in range(5)
    ]
    ax.legend(
        handles=type_handles + risk_handles,
        loc="upper left", bbox_to_anchor=(1.0, 1.0),
        fontsize=8, framealpha=0.85
    )

    ax.set_title(
        f"CMIP6 SSP585 未来气候情景下基础设施受损分布\n",
        fontsize=11, pad=5
    )
    ax.set_xlabel("经度")
    ax.set_ylabel("纬度")
    ax.set_xlim(108, 112)
    ax.set_ylim(17, 21)
    ax.set_aspect('equal')

    plt.savefig(
        "hainan_infra_impact_ssp585.png",
        dpi=150,
        bbox_inches="tight",
        pad_inches=0.3
    )
    print("\n图像已保存至 hainan_infra_impact_ssp585.png")
    plt.show()



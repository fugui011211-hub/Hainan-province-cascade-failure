# 六、未来台风轨迹生成（核心）

def generate_future_tc_tracks(cfg: ScenarioConfig, climate_data: dict):
    """
    基于 CMIP6 气候要素生成未来台风轨迹集合。

    物理假设（与文献一致）：
      -SSP585 情景下 WNP 台风强度偏强，最大风速乘以强化因子
      -路径生成：从初始位置沿随机游走轨迹移动，受引导气流约束
      -台风生命期：72–168 h（3–7天）
      -生成台风数：50–200 条（由区域气候条件决定）

    Parameters
    ----------
    cfg          : ScenarioConfig
    climate_data : dict，来自 load_cmip6_data()

    Returns
    -------
    climada.hazard.TCTracks
      每条轨迹包含 time / lon / lat / max_sustained_wind / time_step 变量
    """
    from climada.hazard import TCTracks

    lon_min, lat_min, lon_max, lat_max = cfg.region_bounds
    sst_mean       = climate_data["sst"].mean()
    wind_shear_mean = climate_data["wind_shear"].mean()

    # ── 气候条件对台风活动的调制因子 ─────────────────────────────────────────
    # SST 越高、风切变越低，台风生成数越多、强度越强
    intensity_factor = 1.0 + 0.12 * sst_mean - 0.03 * (wind_shear_mean - 8.0)
    intensity_factor = np.clip(intensity_factor, 0.85, 1.35)

    # 台风数量：基准 100 条，由气候调制因子调整
    n_tracks = int(np.clip(100 * intensity_factor, 50, 200))

    print(f"\n  [轨迹生成] SST均值: {sst_mean:.2f}℃  风切变均值: {wind_shear_mean:.2f} m/s")
    print(f"  [轨迹生成] 强度调制因子: {intensity_factor:.3f}")
    print(f"  [轨迹生成] 计划生成台风数: {n_tracks}")

    rng = np.random.default_rng(seed=42)

    # ── 未来气候期时间轴（用于 time 字段，仅年份有物理意义） ─────────────────
    year_start, year_end = cfg.future_period
    future_years = np.arange(year_start, year_end + 1)

    # ── 台风季节月份（6–11 月，峰值 8–10 月） ────────────────────────────────
    month_weights = np.array([0.02, 0.06, 0.16, 0.28, 0.26, 0.16, 0.06])  # 6–12月
    month_choices = np.arange(6, 13)

    datasets = []   # 存储每条轨迹的 xarray.Dataset

    for i in range(n_tracks):
        # ── 随机选取年份与月份 ───────────────────────────────────────────────
        year  = rng.choice(future_years)
        month = rng.choice(month_choices, p=month_weights / month_weights.sum())

        # ── 台风生命期：72–168 h，步长 3 h ──────────────────────────────────
        duration_h = int(rng.integers(72, 169, endpoint=True))
        dt_h       = 3
        n_steps    = duration_h // dt_h + 1

        # ── 时间轴（xarray 要求 datetime64） ────────────────────────────────
        t0     = np.datetime64(f"{year}-{month:02d}-{rng.integers(1, 25):02d}T00")
        times  = np.array([t0 + np.timedelta64(k * dt_h, 'h') for k in range(n_steps)])

        # ── 初始位置：在研究区域外围生成，路径穿越研究区 ─────────────────────
        # 台风一般从研究区东侧或南侧进入
        init_lon = rng.uniform(lon_min - 3, lon_max + 3)
        init_lat = rng.uniform(lat_min - 2, lat_max + 1)

        # ── 路径生成：随机游走 + 主导移向（WNP 台风主体北偏西移） ───────────
        # 每步移动量（度）
        dx_mean = rng.uniform(-0.20, 0.05)   # 西移分量（负值）
        dy_mean = rng.uniform( 0.05, 0.20)   # 北移分量（正值）

        dx = rng.normal(dx_mean, 0.08, n_steps)   # 经度增量
        dy = rng.normal(dy_mean, 0.06, n_steps)   # 纬度增量

        lons_track = init_lon + np.cumsum(dx)
        lats_track = init_lat + np.cumsum(dy)

        # ── 最大风速时序（knots）── 生命期抛物线廓型 ─────────────────────────
        # SSP585 强化：基准 40–80 kt，乘以强度调制因子
        vmax_peak_kt = rng.uniform(40, 85) * intensity_factor
        vmax_peak_kt = np.clip(vmax_peak_kt, 30, 120)

        # 生命期抛物线：发展→成熟→衰减
        t_norm    = np.linspace(0, 1, n_steps)
        peak_pos  = rng.uniform(0.3, 0.55)         # 峰值在生命期的相对位置
        vmax_curve = np.exp(-((t_norm - peak_pos) / 0.25) ** 2)
        vmax_track = (
            vmax_peak_kt * vmax_curve
            + rng.normal(0, 2.0, n_steps)           # 随机扰动
        ).clip(15, 150)
        # ── 根据最大风速计算台风等级（category） ─────────────────────
        vmax_max = vmax_track.max()  # 单位：knots

        if vmax_max < 34:
            cat = -1  # 热带低压
        elif vmax_max < 64:
            cat = 0  # 热带风暴
        elif vmax_max < 83:
            cat = 1
        elif vmax_max < 96:
            cat = 2
        elif vmax_max < 113:
            cat = 3
        elif vmax_max < 137:
            cat = 4
        else:
            cat = 5

        # ── 构建 xarray.Dataset（_assign_damage_times 要求的字段结构） ────────
        # [修复] time_step 作为与 time 同长度的一维数据变量，而非 attrs
        time_step_arr = np.full(len(times), dt_h, dtype=np.float32)

        # ── 构造气压字段 ─────────────────────────────
        # 环境气压（hPa）→ 一般 1008–1015
        env_pressure = np.full(n_steps, 1010.0, dtype=np.float32)
        # 中心气压（hPa）→ 与强度相关（简单经验关系）
        # 风速越大 → 气压越低
        central_pressure = 1010 - (vmax_track * 0.8)  # 可调系数
        central_pressure = np.clip(central_pressure, 850, 1010)
        # 最大风速半径（km）→ 简化设定
        rmw = np.full(n_steps, 30.0, dtype=np.float32)
        ds = xr.Dataset(
            {
                "max_sustained_wind": ("time", vmax_track.astype(np.float32)),
                "lon": ("time", lons_track.astype(np.float32)),
                "lat": ("time", lats_track.astype(np.float32)),
                "time_step": ("time", time_step_arr),

                "environmental_pressure": ("time", env_pressure),
                "central_pressure": ("time", central_pressure),
                "radius_max_wind": ("time", rmw),
                "basin": ("time", np.array(["WP"] * len(times))),
            },
            coords={"time": times},
        )
        ds.attrs["max_sustained_wind_unit"] = "knots"
        ds.attrs["central_pressure_unit"] = "hPa"
        ds.attrs["environmental_pressure_unit"] = "hPa"
        ds.attrs["radius_max_wind_unit"] = "km"

        # CLIMADA TCTracks 额外需要的属性
        ds.attrs["sid"]           = f"SSP585_{cfg.gcm}_{year}{month:02d}_{i:04d}"
        ds.attrs["name"]          = f"FUTURE_TC_{i:04d}"
        ds.attrs["orig_event_flag"] = True
        ds.attrs["basin"]         = "WP"
        ds.attrs["category"] = int(cat)
        datasets.append(ds)

    # ── 封装为 TCTracks ───────────────────────────────────────────────────────
    tc_tracks = TCTracks()
    tc_tracks.data = datasets

    # 诊断信息
    all_vmax = np.concatenate([
        ds["max_sustained_wind"].values for ds in datasets
    ])
    print(f"  [轨迹生成] 实际生成台风数: {len(datasets)}")
    print(f"  [轨迹生成] 最大风速范围: "
          f"{all_vmax.min():.1f} – {all_vmax.max():.1f} knots")
    print(f"  [轨迹生成] 最大风速均值: {all_vmax.mean():.1f} knots")

    return tc_tracks



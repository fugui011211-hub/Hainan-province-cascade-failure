RED_LEVELS = [
    "#FE5757",
    "#EA1E20",
    "#BE0208",
    "#9C000D",
    "#790105",
]


def _prob_to_color(prob: float, node_type: str) -> str:
    """将损伤概率映射为显示颜色：无损伤返回类型固定色，有损伤返回对应红色级别。"""
    if prob <= 0:
        return TYPE_COLOR[node_type]
    level = min(int(prob * 4), 4)   # [0, 1] → 离散级别 0–4
    return RED_LEVELS[level]


